# --- Netlify DB (Postgres / Neon) ---
# Auto-injected by Netlify once you run `netlify db init` and link the project.
# NETLIFY_DATABASE_URL is preferred; DATABASE_URL is read as a fallback.
# For local dev against a Neon branch you can set one here:
# NETLIFY_DATABASE_URL="postgres://..."
# DATABASE_URL="postgres://..."

# --- Enrichment (T3) ---
ENRICHMENT_PROVIDER="tinyfish"
TINYFISH_API_KEY=""
# Optional structured provider for LinkedIn/GitHub/Crunchbase URLs:
# ENRICHMENT_PROVIDER="brightdata"
# BRIGHTDATA_API_KEY=""
# BRIGHTDATA_CRUNCHBASE_DATASET_ID=""
# Optional fallback provider:
# FIRECRAWL_API_KEY=""

# Optional: GitHub API works unauthenticated at 60 requests/hour/IP.
# Set a token ONLY for higher rate limits (5000/hr). Leave unset to go without.
# GITHUB_TOKEN=""

# --- Scoring (T4) ---
# Netlify AI Gateway injects ANTHROPIC_API_KEY and ANTHROPIC_BASE_URL automatically
# at runtime when deployed with AI Gateway enabled. No key is needed in production.
# For LOCAL scoring under `netlify dev` (where the Gateway isn't injected), set your
# own Anthropic key here to call the API directly:
# ANTHROPIC_API_KEY=""
# Optional model override (defaults to claude-opus-4-8):
# ANTHROPIC_MODEL="claude-opus-4-8"
